{
    "$schema": "https://unpkg.com/@holocron.so/vite/src/schema.json",
  "name": "Playwriter",
  "description": "Docs for Playwriter, the CLI and MCP that lets agents control your real Chrome browser.",
  "logo": {
    "light": "/playwriter-logo.svg",
    "dark": "/playwriter-logo.svg",
    "href": "/"
  },
  "favicon": {
    "light": "/favicon-32.png",
    "dark": "/favicon-32.png"
  },
  "colors": {
